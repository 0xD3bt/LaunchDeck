# ============================================================
# LaunchDeck easy setup
# ============================================================

# Most users only need to set the values in this section.
# If you just want LaunchDeck running, fill this section first and stop here.

# Imported Solana wallet private key for slot key1.
# Optional custom label syntax: <privatekey>,<customname>
# Example: SOLANA_PRIVATE_KEY=5K...,Main Wallet
# Add more wallets with the same pattern: SOLANA_PRIVATE_KEY2, SOLANA_PRIVATE_KEY3, SOLANA_PRIVATE_KEY4, etc.
# Untagged wallets show as #1, #2, #3 based on the key slot.
SOLANA_PRIVATE_KEY=
# Imported Solana wallet private key for slot key2.
# Example with custom name: SOLANA_PRIVATE_KEY2=5K...,Sniper 2
SOLANA_PRIVATE_KEY2=

# Main Solana RPC URL used for reads, confirmations, and general runtime RPC behavior.
# Recommended: use Helius Gatekeeper HTTP here:
#   https://beta.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Helius dev tier is strongly recommended if you care about maximum performance, watcher quality,
# or plan to run multiple snipes / follow actions.
SOLANA_RPC_URL=

# Solana websocket URL for live watchers. This can be a ws:// or wss:// URL.
# Required for optimal live snipes/sells and follow-daemon watcher behavior.
# Recommended: use Helius standard websocket here:
#   wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Set this explicitly instead of relying on RPC-derived websocket guessing.
SOLANA_WS_URL=

# Optional Helius HTTP RPC used only for Helius priority-fee estimates (getPriorityFeeEstimate).
# When blank, estimates use SOLANA_RPC_URL.
HELIUS_RPC_URL=

# Optional Helius websocket URL for transactionSubscribe watchers.
# When blank, LaunchDeck uses a Helius-hosted SOLANA_WS_URL (or other Helius watch endpoint)
# automatically when available.
HELIUS_WS_URL=

# Optional extra submit-only RPC endpoints for `standard-rpc` mode fanout.
# Comma-separated. LaunchDeck keeps `SOLANA_RPC_URL` as the primary read/confirm RPC and will
# fan the same signed transaction out to these additional endpoints in parallel on the optimized
# standard-RPC path. Current standard-RPC transport also forces skipPreflight=true and maxRetries=0.
# Example:
# LAUNCHDECK_EXTRA_STANDARD_RPC_SEND_URLS=https://rpc-a.example.com,https://rpc-b.example.com
LAUNCHDECK_EXTRA_STANDARD_RPC_SEND_URLS=

# Suggested alternate Solana RPC URL used only for startup warmup calls and block-height observation.
# Leave blank to reuse SOLANA_RPC_URL. Useful if you want to keep warm/cache traffic and block-height
# reads off your main launch RPC.
# Recommended: use a separate low-priority Shyft RPC with a free API key for this path
# (https://shyft.to/) so startup warm and block-height reads do not drain your main
# Helius RPC budget for no reason.
LAUNCHDECK_WARM_RPC_URL=

# Helius enhanced transactionSubscribe watcher toggle.
# Blank defaults to true. LaunchDeck probes the available Helius websocket on startup / warm and
# uses transactionSubscribe when that probe succeeds, otherwise it falls back to standard websocket.
LAUNCHDECK_ENABLE_HELIUS_TRANSACTION_SUBSCRIBE=true

# Benchmark detail level for reports.
# This only controls timing detail. It does not enable send/confirm block-height capture.
# That is a separate setting:
# - env default: `LAUNCHDECK_TRACK_SEND_BLOCK_HEIGHT`
# - runtime field: `execution.trackSendBlockHeight`
# Supported values:
# - off: benchmark payloads disabled
# - light: core timings without benchmark-only diagnostics
# - full: full grouped timings plus reporting overhead timing
# Legacy compatibility: `basic` is still accepted and maps to `light`.
# Blank defaults to `full`.
LAUNCHDECK_BENCHMARK_MODE=

# Default for `execution.trackSendBlockHeight`.
# When enabled, reports also record observed block height at send time and confirmation time.
# Supported true values: 1, true, yes, on
# This env default is only applied when `LAUNCHDECK_BENCHMARK_MODE=full` (or blank/default full).
# `off` and `light` keep it disabled by default. An explicit `execution.trackSendBlockHeight`
# value in a request/preset can still override that default intentionally.
LAUNCHDECK_TRACK_SEND_BLOCK_HEIGHT=

# Default region profile for region-aware providers when no provider-specific region override is set.
# Regional groups: global, us, eu, asia, or metros: slc, ewr, lon, fra, ams, sg, tyo (comma-separated ok).
# Recommended: set this to your nearest region because provider fanout usually reaches more endpoints
# in that region and is faster/more reliable than pinning a single sender or bundle endpoint.
# In most setups, USER_REGION is the right choice and explicit endpoint overrides should stay blank.
USER_REGION=

# Metadata upload provider. Defaults to pump-fun when blank. Use pinata to upload through Pinata: https://pinata.cloud/
LAUNCHDECK_METADATA_UPLOAD_PROVIDER=

# Required when metadata provider is pinata. Get it from https://pinata.cloud/
PINATA_JWT=

# ============================================================
# Advanced settings
# ============================================================

# Everything below is optional advanced tuning and overrides.
# Leave these unset unless you specifically know you want to change the default behavior.

# Startup warm / keep-warm controls.
#
# `LAUNCHDECK_WARM_RPC_URL` is the non-critical warm/block-height path. Leave blank to reuse
# `SOLANA_RPC_URL`. A cheaper Shyft RPC is a good fit here if you want to keep warm traffic off
# your main execution RPC.
#
# `LAUNCHDECK_ENABLE_STARTUP_WARM=true|false`
# One-shot startup warm toggle. Recommended default: keep this on.
LAUNCHDECK_ENABLE_STARTUP_WARM=true
#
# `LAUNCHDECK_ENABLE_CONTINUOUS_WARM=true|false`
# Shared active keep-warm toggle. Recommended default: keep this on while the browser/app is being
# used. A cheap Shyft `LAUNCHDECK_WARM_RPC_URL` keeps the warm RPC path inexpensive for most users.
LAUNCHDECK_ENABLE_CONTINUOUS_WARM=true
#
# `LAUNCHDECK_ENABLE_IDLE_WARM_SUSPEND=true|false`
# Automatically suspend active keep-warm after idle time. Recommended default: keep this on.
LAUNCHDECK_ENABLE_IDLE_WARM_SUSPEND=true
#
# `LAUNCHDECK_IDLE_WARM_TIMEOUT_MS`
# Idle timeout before active keep-warm suspends. Blank defaults to 75000ms.
LAUNCHDECK_IDLE_WARM_TIMEOUT_MS=
#
# `LAUNCHDECK_CONTINUOUS_WARM_INTERVAL_MS`
# Active keep-warm cadence. Blank defaults to 50000ms.
LAUNCHDECK_CONTINUOUS_WARM_INTERVAL_MS=
#
# Legacy fallback: completely disable startup warmup.
# Supported values: 1, true, yes, on
# This is only consulted when `LAUNCHDECK_ENABLE_STARTUP_WARM` is unset.
LAUNCHDECK_DISABLE_STARTUP_WARM=

# Shared block-height cache TTL in milliseconds. All block-height readers reuse one cached value
# per RPC+commitment for this long instead of each making their own getBlockHeight call.
# Blank defaults to 200ms.
LAUNCHDECK_BLOCK_HEIGHT_CACHE_TTL_MS=

# Maximum age for sampled block-height snapshots used by reporting/diagnostic paths before they
# force a fresh read. Blank defaults to 1000ms.
LAUNCHDECK_BLOCK_HEIGHT_SAMPLE_MAX_AGE_MS=

# Follow offset worker cadence in milliseconds for post-confirmation `targetBlockOffset > 0`
# actions. Blank defaults to 400ms.
LAUNCHDECK_FOLLOW_OFFSET_POLL_INTERVAL_MS=
#
# Optional low-request follow offset mode. When enabled, the follow daemon uses an approximate
# local timer after confirmation instead of real `getBlockHeight` polling for offset waits.
# This is approximate behavior, env-only, and disabled by default.
LAUNCHDECK_ENABLE_APPROXIMATE_FOLLOW_OFFSET_TIMER=
#
# Legacy note: `LAUNCHDECK_FOLLOW_BLOCK_HEIGHT_REFRESH_MS` no longer drives offset timing after the
# offset-worker switch. Keep it unset unless a future path reintroduces a dedicated follow
# block-height refresher for non-offset needs.
LAUNCHDECK_FOLLOW_BLOCK_HEIGHT_REFRESH_MS=

# Outbound RPC / provider HTTP traffic meter for the UI (rolling 60s count shown as N/min).
# Set to 0, false, no, or off to disable counting entirely (record path becomes a no-op).
# Blank defaults to enabled.
LAUNCHDECK_RPC_TRAFFIC_METER=

# Helius priority fee selector. Blank defaults to high.
# Supported values: recommended, none, low, medium, high, veryHigh, unsafeMax
LAUNCHDECK_AUTO_FEE_HELIUS_PRIORITY_LEVEL=
#
# Helius priority-fee refresh cadence in milliseconds for background auto-fee snapshots.
# Blank defaults to 6000ms.
LAUNCHDECK_HELIUS_PRIORITY_REFRESH_INTERVAL_MS=
#
# Jito tip percentile selector. Blank defaults to p99.
# Supported values: p25, p50, p75, p95, p99
LAUNCHDECK_AUTO_FEE_JITO_TIP_PERCENTILE=
#
# Frontend wallet-balance refresh cadence in milliseconds. The UI still refreshes after launches,
# and saves the last refresh timestamp in localStorage; this controls the steady-state background loop.
# Blank defaults to 30000ms.
LAUNCHDECK_WALLET_STATUS_REFRESH_INTERVAL_MS=

# Rust host port. Defaults to 8789 when blank.
LAUNCHDECK_PORT=

# Engine localhost control token. Defaults to 4815927603149027 when blank.
LAUNCHDECK_ENGINE_AUTH_TOKEN=

# Follow daemon transport. Defaults to local-http.
LAUNCHDECK_FOLLOW_DAEMON_TRANSPORT=local-http

# Explicit follow daemon base URL. Defaults to http://127.0.0.1:<LAUNCHDECK_FOLLOW_DAEMON_PORT>.
LAUNCHDECK_FOLLOW_DAEMON_URL=

# Follow daemon port. Defaults to 8790 when blank.
LAUNCHDECK_FOLLOW_DAEMON_PORT=

# Follow daemon localhost control token. Defaults to 4815927603149027 when blank.
LAUNCHDECK_FOLLOW_DAEMON_AUTH_TOKEN=

# Auto-fee estimator controls for the main launch/buy/sell fee engine.
# Recommended for best success rate: use veryHigh + p99 and also set a Max Auto Fee in the UI
# to cap what you are willing to pay.

# Default compute unit limits used when a flow does not set tx.computeUnitLimit explicitly.
# These defaults are estimates from observed successful transactions, with a +10% safety buffer
# applied and then rounded up to simple values.
# If you set tx.computeUnitLimit in a launch config, that explicit value still wins for launch/build
# paths that already support a manual override.
LAUNCHDECK_LAUNCH_COMPUTE_UNIT_LIMIT=
LAUNCHDECK_AGENT_SETUP_COMPUTE_UNIT_LIMIT=
LAUNCHDECK_FOLLOW_UP_COMPUTE_UNIT_LIMIT=
LAUNCHDECK_SNIPER_BUY_COMPUTE_UNIT_LIMIT=
LAUNCHDECK_DEV_AUTO_SELL_COMPUTE_UNIT_LIMIT=
LAUNCHDECK_LAUNCH_USD1_TOPUP_COMPUTE_UNIT_LIMIT=

# Max simultaneous follow jobs. Blank or 0 means uncapped.
LAUNCHDECK_FOLLOW_MAX_ACTIVE_JOBS=

# Max concurrent follow transaction compiles. Blank or 0 means uncapped.
LAUNCHDECK_FOLLOW_MAX_CONCURRENT_COMPILES=

# Max concurrent follow sends. Blank or 0 means uncapped.
LAUNCHDECK_FOLLOW_MAX_CONCURRENT_SENDS=

# How long compile/send waits for daemon capacity before failing. Defaults to 5000ms.
# This only matters if one of the follow capacity caps above is set.
LAUNCHDECK_FOLLOW_CAPACITY_WAIT_MS=

# Shared helper process timeout for launchpad helper scripts such as Bonk/Bags. Blank defaults to 30s.
LAUNCHDECK_LAUNCHPAD_HELPER_TIMEOUT_MS=

# Max concurrent launchpad helper script invocations. Blank defaults to 4.
LAUNCHDECK_LAUNCHPAD_HELPER_MAX_CONCURRENCY=

# Optional persistent helper worker toggles for helper-backed launchpads. Recommended default: on.
# These keep one long-lived Node helper process alive instead of spawning a new helper for each
# request. Set either one to `false` if you intentionally want one-shot helper execution instead.
LAUNCHDECK_ENABLE_BAGS_HELPER_WORKER=true
LAUNCHDECK_ENABLE_BONK_HELPER_WORKER=true


# ------------------------------------------------------------
# Advanced: local data overrides
# ------------------------------------------------------------

# Base directory for most LaunchDeck local state. Defaults to ./.local/launchdeck
LAUNCHDECK_LOCAL_DATA_DIR=

# Persisted launch report directory. Defaults under the local data directory.
LAUNCHDECK_SEND_LOG_DIR=

# Engine runtime state file path. Defaults to ./.local/engine-runtime.json
# instead of living under LAUNCHDECK_LOCAL_DATA_DIR.
LAUNCHDECK_ENGINE_RUNTIME_PATH=

# Follow daemon state file path. Defaults under the local data directory.
LAUNCHDECK_FOLLOW_DAEMON_STATE_PATH=


# ------------------------------------------------------------
# Advanced: provider routing and endpoint overrides
# ------------------------------------------------------------

# Provider-specific Helius Sender region override. When set, this wins over USER_REGION
# for Helius Sender only.
USER_REGION_HELIUS_SENDER=

# Provider-specific Hello Moon region override. When set, this wins over USER_REGION
# for Hello Moon routing, including QUIC and bundle endpoint selection.
USER_REGION_HELLOMOON=

# Provider-specific Jito Bundle region override. When set, this wins over USER_REGION
# for Jito Bundle only.
USER_REGION_JITO_BUNDLE=

# Explicit Helius Sender endpoint override.
# No override: keep region fanout routing
# (USER_REGION_HELIUS_SENDER -> USER_REGION -> global) instead of pinning a single sender URL.
# Recommended: leave blank unless you intentionally need one specific endpoint.
# Warm paths use HTTP GET on the Sender /ping URL next to /fast, not your SOLANA_RPC_URL.
HELIUS_SENDER_ENDPOINT=

# Optional alternate Helius Sender base URL.
HELIUS_SENDER_BASE_URL=

# Explicit Hello Moon QUIC endpoint override.
# Expected format: host:port, for example fra.lunar-lander.hellomoon.io:16888
# No override: keep region fanout routing
# (USER_REGION_HELLOMOON -> USER_REGION -> global) instead of pinning one endpoint.
HELLOMOON_QUIC_ENDPOINT=

# Enable Hello Moon QUIC MEV protection on the connection.
# Supported true values: 1, true, yes, on
HELLOMOON_MEV_PROTECT=

# Comma-separated Jito bundle base URLs. Used when the explicit endpoints below are not set.
# Region filtering still applies to these base URLs.
JITO_BUNDLE_BASE_URLS=

# Explicit Jito sendBundle endpoint override. When this and the status endpoint below are set,
# LaunchDeck bypasses region fanout and uses only these explicit bundle endpoints.
# Recommended: leave blank unless you intentionally need one specific endpoint pair.
JITO_SEND_BUNDLE_ENDPOINT=

# Explicit Jito bundle status endpoint override. When this and the send endpoint above are set,
# LaunchDeck bypasses region fanout and uses only these explicit bundle endpoints.
# Recommended: leave blank unless you intentionally need one specific endpoint pair.
JITO_BUNDLE_STATUS_ENDPOINT=


# ------------------------------------------------------------
# Advanced: wallet overrides
# ------------------------------------------------------------

# Optional filesystem keypair path for the main selected wallet.
SOLANA_KEYPAIR_PATH=


# ------------------------------------------------------------
# Advanced: metadata upload options
# ------------------------------------------------------------
# Quick-start copies for metadata provider and Pinata JWT live at the top of this file.


# ------------------------------------------------------------
# Advanced: launchpad/provider integrations
# ------------------------------------------------------------

# Bags API key. Required for Bags launchpad usage.
BAGS_API_KEY=

# Bags API base URL override.
BAGS_API_BASE_URL=

# Hello Moon API key for Lunar Lander QUIC submission.
HELLOMOON_API_KEY=

# Minimum Bags setup Jito tip in lamports. Blank defaults to 1000.
LAUNCHDECK_BAGS_SETUP_JITO_TIP_MIN_LAMPORTS=

# Maximum Bags setup Jito tip in lamports. Blank defaults to 1000000.
LAUNCHDECK_BAGS_SETUP_JITO_TIP_CAP_LAMPORTS=


# ------------------------------------------------------------
# Advanced: developer tools and script compatibility
# ------------------------------------------------------------

# Base URL override for the browser matrix scripts.
LAUNCHDECK_MATRIX_BASE_URL=

# Manual script compatibility aliases used by some standalone utility scripts.
# Main LaunchDeck runtime does not need these when SOLANA_RPC_URL is already set.
# HELIUS_RPC_URL / HELIUS_WS_URL (see Solana section above) are also read by the Rust engine.
RPC_URL=
