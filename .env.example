# ============================================================
# LaunchDeck easy setup
# ============================================================

# Copy this file to `.env` and fill in the values below.
# If you want the full variable list, advanced tuning, or provider overrides, see `.env.advanced`.

# Imported Solana wallet private key for slot key1.
# Optional custom label syntax: <privatekey>,<customname>
# Example: SOLANA_PRIVATE_KEY=5K...,Main Wallet
# Add more wallets with the same pattern: SOLANA_PRIVATE_KEY2, SOLANA_PRIVATE_KEY3, SOLANA_PRIVATE_KEY4, etc.
# Untagged wallets show as #1, #2, #3 based on the key slot.
SOLANA_PRIVATE_KEY=

# Imported Solana wallet private key for slot key2.
# Example with custom name: SOLANA_PRIVATE_KEY2=5K...,Sniper 2
SOLANA_PRIVATE_KEY2=

# Main Solana RPC URL used for reads, confirmations, and general runtime RPC behavior.
# Recommended default: use Helius Gatekeeper HTTP here:
#   https://beta.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Insert your key immediately after `api-key=`.
# Helius dev tier is strongly recommended if you do multiple snipes / follow actions, otherwise
# you are more likely to run into watcher and RPC rate limits.
SOLANA_RPC_URL=

# Solana websocket URL for live watchers. This can be a ws:// or wss:// URL.
# Required for optimal live snipes/sells and follow-daemon watcher behavior.
# Recommended default: use standard Helius websocket here:
#   wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Insert your key immediately after `api-key=`.
# This is the websocket path LaunchDeck can upgrade with Helius `transactionSubscribe` when
# LAUNCHDECK_ENABLE_HELIUS_TRANSACTION_SUBSCRIBE=true and your Helius tier supports it.
# Set this explicitly instead of relying on RPC-derived websocket guessing.
SOLANA_WS_URL=

# Optional Helius HTTP RPC used only for Helius priority-fee estimates (getPriorityFeeEstimate).
# When blank, estimates use SOLANA_RPC_URL. Set this when your main RPC is not Helius but you
# still want Helius-backed priority fee data. Example:
#   https://beta.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_RPC_URL=

# Optional Helius websocket URL used for transactionSubscribe watchers when
# LAUNCHDECK_ENABLE_HELIUS_TRANSACTION_SUBSCRIBE is true. When blank, LaunchDeck uses a Helius
# websocket derived from SOLANA_WS_URL / watch endpoints when the host is Helius-hosted. Example:
#   wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_WS_URL=

# Suggested alternate Solana RPC URL used for startup warmup, continuous keep-warm probes,
# and block-height observation. Leave blank to reuse SOLANA_RPC_URL.
# Recommended: use a separate low-priority Shyft RPC with a free API key for this path
# so warm/cache traffic and block-height reads do not drain your main Helius RPC budget.
# Example:
#   https://rpc.fra.shyft.to?api_key=YOUR_SHYFT_API_KEY
# Insert your key immediately after `api_key=`.
LAUNCHDECK_WARM_RPC_URL=

# One-shot startup warm toggle. Blank defaults to true.
LAUNCHDECK_ENABLE_STARTUP_WARM=

# Shared active keep-warm toggle. Blank defaults to true while the browser/app is being used.
# Important: if you have different live providers configured for creation, buy, and sell,
# LaunchDeck will keep all of those active provider routes warm, which can become very consuming.
LAUNCHDECK_ENABLE_CONTINUOUS_WARM=

# Automatically suspend active keep-warm after idle time. Blank defaults to true.
LAUNCHDECK_ENABLE_IDLE_WARM_SUSPEND=

# Idle timeout before active keep-warm suspends. Blank defaults to 30000ms.
LAUNCHDECK_IDLE_WARM_TIMEOUT_MS=

# Active keep-warm cadence. Blank defaults to 10000ms.
LAUNCHDECK_CONTINUOUS_WARM_INTERVAL_MS=

# Helius dev tier users only: enable Helius enhanced transactionSubscribe watchers when
# your Helius websocket endpoint supports it. This upgrades the market watcher path beyond
# standard websocket subscriptions when available. Defaults to false and automatically falls
# back to standard websocket watchers if unsupported.
# Recommended: set this to true when SOLANA_WS_URL points at Helius standard websocket and your
# plan supports transactionSubscribe.
LAUNCHDECK_ENABLE_HELIUS_TRANSACTION_SUBSCRIBE=

# Helius priority-fee refresh cadence in milliseconds for background auto-fee snapshots.
# Blank defaults to 6000ms.
LAUNCHDECK_HELIUS_PRIORITY_REFRESH_INTERVAL_MS=

# Frontend wallet-balance refresh cadence in milliseconds. The UI still refreshes after launches,
# and stores the last refresh time in localStorage so reloads can reuse that timestamp.
# Blank defaults to 30000ms.
LAUNCHDECK_WALLET_STATUS_REFRESH_INTERVAL_MS=

# Benchmark detail level for reports.
# This only controls timing detail. It does not enable send/confirm block-height capture.
# That is a separate setting:
# - env default: `LAUNCHDECK_TRACK_SEND_BLOCK_HEIGHT`
# - runtime field: `execution.trackSendBlockHeight`
# Supported values:
# - off: benchmark payloads disabled
# - light: core timings without benchmark-only diagnostics
# - full: full grouped timings plus reporting overhead timing
# Legacy compatibility: `basic` is still accepted and maps to `light`.
# Blank defaults to `full`.
LAUNCHDECK_BENCHMARK_MODE=

# Default for `execution.trackSendBlockHeight`.
# When enabled, reports also record observed block height at send time and confirmation time.
# Supported true values: 1, true, yes, on
# This env default is only applied when `LAUNCHDECK_BENCHMARK_MODE=full` (or blank/default full).
# `off` and `light` keep it disabled by default. An explicit `execution.trackSendBlockHeight`
# value in a request/preset can still override that default intentionally.
LAUNCHDECK_TRACK_SEND_BLOCK_HEIGHT=

# Follow offset worker cadence in milliseconds for post-confirmation `targetBlockOffset > 0`
# actions. Blank defaults to 400ms.
LAUNCHDECK_FOLLOW_OFFSET_POLL_INTERVAL_MS=

# Optional low-request follow offset mode. When enabled, the follow daemon uses an approximate
# local 400ms timer after confirmation instead of real `getBlockHeight` polling for offset waits.
# This is approximate behavior and stays off by default.
LAUNCHDECK_ENABLE_APPROXIMATE_FOLLOW_OFFSET_TIMER=

# Default region profile for region-aware providers when no provider-specific region override is set.
# Regional groups: global, us, eu, asia. Or pin Helius Sender metros: slc, ewr, lon, fra, ams, sg, tyo
# (comma-separated for multiple, e.g. fra,ams). ny is normalized to ewr. The old "west" profile is removed.
# Recommended: set this to your nearest region because provider fanout usually reaches more endpoints
# in that region and is faster/more reliable than pinning a single sender or bundle endpoint.
# In most setups, USER_REGION is the right choice and explicit endpoint overrides should stay blank.
USER_REGION=

# Metadata upload provider. Defaults to pump-fun when blank. Use pinata to upload through Pinata: https://pinata.cloud/
LAUNCHDECK_METADATA_UPLOAD_PROVIDER=

# Required when metadata provider is pinata. Get it from https://pinata.cloud/
PINATA_JWT=

# Optional Bags API key. Only needed if you use Bags launchpad flows.
BAGS_API_KEY=

# Optional Hello Moon QUIC API key. Only needed if you want to use the Hello Moon provider.
# Keep your normal confirmation RPC in SOLANA_RPC_URL; pairing Hello Moon sends with a Shyft RPC
# for reads/warm/block-height is a good low-friction setup.
HELLOMOON_API_KEY=
