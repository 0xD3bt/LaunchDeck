# ============================================================
# LaunchDeck easy setup
# ============================================================
#
# Copy this file to `.env` and fill in the values below.
# Most users only need this starter set.
# If you want every env var, advanced tuning, or provider overrides, see `.env.advanced`.

# ------------------------------------------------------------
# Wallets
# ------------------------------------------------------------
#
# Format:
# SOLANA_PRIVATE_KEY=<privatekey>
# SOLANA_PRIVATE_KEY2=<privatekey>,<tag>
#
# Tagged example:
# SOLANA_PRIVATE_KEY=5K...,Main Wallet
# SOLANA_PRIVATE_KEY2=5K...,Sniper 2
# SOLANA_PRIVATE_KEY3=5K...,Sniper 3
#
# You can load as many wallets as you want with the same pattern:
# SOLANA_PRIVATE_KEY, SOLANA_PRIVATE_KEY2, SOLANA_PRIVATE_KEY3, ...
#
# Untagged wallets show as #1, #2, #3 based on the key slot.
SOLANA_PRIVATE_KEY=
SOLANA_PRIVATE_KEY2=
SOLANA_PRIVATE_KEY3=
SOLANA_PRIVATE_KEY4=
SOLANA_PRIVATE_KEY5=
SOLANA_PRIVATE_KEY6=
SOLANA_PRIVATE_KEY7=
SOLANA_PRIVATE_KEY8=
SOLANA_PRIVATE_KEY9=
SOLANA_PRIVATE_KEY10=

# ------------------------------------------------------------
# Core RPC / websocket
# ------------------------------------------------------------
#
# Main Solana HTTP RPC used for reads, confirmations, and general runtime behavior.
# Recommended default: use the Helius Gatekeeper HTTP format below.
# In LaunchDeck benchmarking, this was the fastest Helius HTTP option versus the other common
# Helius RPC URL formats we tested.
# If you do not want to fetch the correct URL from Helius yourself, copy this exact address and
# replace only YOUR_HELIUS_API_KEY:
#   https://beta.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Insert your key immediately after `api-key=`.
SOLANA_RPC_URL=

# Main Solana websocket used for live watchers and follow-daemon realtime behavior.
# Recommended default: use the Helius standard websocket format below.
# In LaunchDeck benchmarking, this was the fastest Helius websocket format we tested for watcher
# use. If you do not want to fetch the correct URL from Helius yourself, copy this exact address
# and replace only YOUR_HELIUS_API_KEY:
#   wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Insert your key immediately after `api-key=`.
SOLANA_WS_URL=

# Default region profile for region-aware providers.
# Regional groups: global, us, eu, asia
# Or metros: slc, ewr, lon, fra, ams, sg, tyo
# Example: USER_REGION=fra,ams
# Recommended:
# - `eu` fans out across Amsterdam + Frankfurt, so we suggest EU users place their server in one of those locations
# - `lon` is exact on Helius, but Hello Moon does not expose a London endpoint, so Hello Moon falls back to the EU set (Amsterdam + Frankfurt)
# - `asia` fans out across Singapore + Tokyo on Helius
# - because those Asia metros are also far apart, we suggest Asia users place their server in one of them and then use the specific metro only (`sg` or `tyo`)
# - Hello Moon does not expose a Singapore endpoint, so Hello Moon `asia` and `sg` fall back to Tokyo
# - `us` fans out across Salt Lake City + Newark
# - because those two US metros are far apart, we suggest US users place their server in either one and then use the specific metro only (`slc` or `ewr`)
# - Helius can route exactly to those metros, but Hello Moon US still fans out across both New York + Ashburn even when `slc` or `ewr` is selected because those are the closest Hello Moon US endpoints
USER_REGION=

# Optional extra RPC used for startup warmup, continuous keep-warm probes, and block-height reads.
# Leave blank to reuse SOLANA_RPC_URL.
# Recommended: use a cheap Shyft RPC here so warm traffic does not drain your main RPC budget.
# Example:
#   https://rpc.fra.shyft.to?api_key=YOUR_SHYFT_API_KEY
# Insert your key immediately after `api_key=`.
LAUNCHDECK_WARM_RPC_URL=

# Optional Helius HTTP override used only for Helius priority-fee estimates.
# In most setups, you do NOT need this because a Helius SOLANA_RPC_URL is picked up automatically.
# Set this only if SOLANA_RPC_URL is non-Helius but you still want Helius fee estimates.
# If you need to set it manually, use the same Gatekeeper HTTP format:
# Example:
#   https://beta.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_RPC_URL=

# Optional Helius websocket override used for Helius transactionSubscribe watchers.
# In most setups, you do NOT need this because a Helius SOLANA_WS_URL is picked up automatically.
# Set this only if SOLANA_WS_URL is non-Helius or you intentionally want a separate Helius watch path.
# If you need to set it manually, use the same standard websocket format:
# Example:
#   wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_WS_URL=

# ------------------------------------------------------------
# Provider-specific optional keys
# ------------------------------------------------------------

# Optional Hello Moon QUIC API key.
# Only needed if you want to use the Hello Moon provider.
# Request access through Hello Moon first.
HELLOMOON_API_KEY=

# Optional Bags API key.
# Only needed if you use Bags launchpad flows.
BAGS_API_KEY=

# ------------------------------------------------------------
# Metadata upload
# ------------------------------------------------------------

# Metadata upload provider.
# Blank/default uses pump-fun.
# Set `pinata` if you want Pinata-backed metadata uploads instead.
LAUNCHDECK_METADATA_UPLOAD_PROVIDER=

# Required only when LAUNCHDECK_METADATA_UPLOAD_PROVIDER=pinata.
# Get it from https://pinata.cloud/
PINATA_JWT=

# ------------------------------------------------------------
# Reports / UI / auto-fee
# ------------------------------------------------------------

# Benchmark detail level for reports.
# Supported values: off, light, full
# Blank defaults to full.
LAUNCHDECK_BENCHMARK_MODE=

# Helius auto-fee priority level.
# Supported values: recommended, none, low, medium, high, veryHigh, unsafeMax
LAUNCHDECK_AUTO_FEE_HELIUS_PRIORITY_LEVEL=high

# Helius priority-fee refresh cadence in milliseconds for background auto-fee snapshots.
LAUNCHDECK_HELIUS_PRIORITY_REFRESH_INTERVAL_MS=6000

# Supported Jito values: p25, p50, p75, p95, p99
LAUNCHDECK_AUTO_FEE_JITO_TIP_PERCENTILE=p99

# Frontend wallet-balance refresh cadence in milliseconds.
LAUNCHDECK_WALLET_STATUS_REFRESH_INTERVAL_MS=30000
